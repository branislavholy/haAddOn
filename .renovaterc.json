{
  "extends": ["config:base"],
  "packageRules": [
    {
      "matchPackagePatterns": ["ghcr.io/home-assistant/"],
      "groupName": "fix(home-assistant-base)"
    }
  ],
  "docker": {
    "enabled": true
  },
  "regexManagers": [
    {
      "fileMatch": ["weather/build\\.yaml"],
      "matchStrings": [
        "(?<depName>ghcr\\.io/home-assistant/[^:]+):(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "docker"
    }
  ]
}
